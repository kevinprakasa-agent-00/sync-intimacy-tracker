{
  "expo": {
    "name": "SYNC - Intimacy Tracker",
    "slug": "sync-intimacy-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ff6b6b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shipit.sync",
      "infoPlist": {
        "NSFaceIDUsageDescription": "SYNC uses Face ID to protect your private data."
      }
    },
    "android": {
      "package": "com.shipit.sync",
      "adaptiveIcon": {
        "backgroundColor": "#ff6b6b",
        "foregroundImage": "./assets/adaptive-icon.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-secure-store",
        {
          "faceIDPermission": "SYNC uses Face ID to protect your private data."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow SYNC to use Face ID."
        }
      ]
    ]
  }
}
